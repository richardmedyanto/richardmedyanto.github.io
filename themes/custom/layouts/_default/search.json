{{- $pages := where .Site.RegularPages "Section" "post" -}}
[
  {{- range $i, $p := $pages -}}
  {{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "description": {{ $p.Description | jsonify }},
    "categories": {{ $p.Params.categories | jsonify }},
    "date": {{ $p.Date.Format "Jan 2, 2006" | jsonify }},
    "content": {{ $p.Plain | truncate 300 | jsonify }}
  }
  {{- end }}
]
